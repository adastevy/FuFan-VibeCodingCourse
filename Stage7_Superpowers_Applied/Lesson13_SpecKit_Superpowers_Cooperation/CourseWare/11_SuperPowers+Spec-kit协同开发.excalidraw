    {
      "id": "-4ev_zx7u1aCugQivwm_w",
      "type": "text",
      "x": 45.28377253379426,
      "y": 16335.305012659152,
      "width": 420,
      "height": 140,
      "angle": 0,
      "strokeColor": "#5a1010",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,

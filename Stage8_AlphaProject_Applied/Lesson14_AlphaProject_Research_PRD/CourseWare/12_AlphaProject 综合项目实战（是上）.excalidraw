    {
      "id": "bCkEJaqOX3j3u6mQZqp0v",
      "type": "text",
      "x": 3076.9151300592507,
      "y": 7212.124590692057,
      "width": 1384,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "hachure",

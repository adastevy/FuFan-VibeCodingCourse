    },
    {
      "id": "uMe2_UYUHzH-n0fGRWAvQ",
      "type": "text",
      "x": 2455.2854886565433,
      "y": 5715.648958963583,
      "width": 1489.579345703125,
      "height": 600,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",

    {
      "id": "vS32QvQfoCUg8mrqCtbO8",
      "type": "rectangle",
      "x": 3249.028631408161,
      "y": 16112.163126852243,
      "width": 1500,
      "height": 1106,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffffff",
      "fillStyle": "solid",

    {
      "id": "9iCOqnctTugJdGXfKYii5",
      "type": "text",
      "x": 986.3711832402948,
      "y": 816.5793041690808,
      "width": 637.9598388671875,
      "height": 650,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",

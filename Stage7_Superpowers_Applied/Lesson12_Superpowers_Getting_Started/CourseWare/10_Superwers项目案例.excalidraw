    {
      "id": "cFdpC7Urk9WNZ-WODUCAy",
      "type": "text",
      "x": 3279.8242933407637,
      "y": 12587.997282726708,
      "width": 1452,
      "height": 378.00000000000006,
      "strokeColor": "#1e1e1e",

    {
      "id": "7Of6E8lW_8SoKSsJqRs10",
      "type": "text",
      "x": 3280.345238432403,
      "y": 11448.469658851842,
      "width": 1452,
      "height": 642.6,
      "strokeColor": "#1e1e1e",

      "id": "zSVYbkdIZuAs0WIjsR8Hy",
      "type": "text",
      "x": 3274.07052159144,
      "y": 17611.725962127162,
      "width": 1452,
      "height": 1152.9,
      "strokeColor": "#1e1e1e",
